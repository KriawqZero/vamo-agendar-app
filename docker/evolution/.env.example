# Modelo de configuração da Evolution API v2 (local).
# Copie para .env e troque AUTHENTICATION_API_KEY por um valor forte:
#   openssl rand -hex 16
# A MESMA chave deve ir em EVOLUTION_GLOBAL_API_KEY no .env.local do app.

# ── Servidor ────────────────────────────────────────────────────────────────
SERVER_URL=http://localhost:8080
SERVER_PORT=8080
LANGUAGE=pt-BR

# ── Autenticação (apikey GLOBAL usada pelo app para criar/gerir instâncias) ─
AUTHENTICATION_API_KEY=troque-esta-chave

# ── Banco (Postgres do compose; hostname = nome do serviço) ────────────────
DATABASE_ENABLED=true
DATABASE_PROVIDER=postgresql
DATABASE_CONNECTION_URI=postgresql://evolution:evolution@postgres:5432/evolution?schema=public
DATABASE_CONNECTION_CLIENT_NAME=evolution_vamoagendar
DATABASE_SAVE_DATA_INSTANCE=true
DATABASE_SAVE_DATA_NEW_MESSAGE=true
DATABASE_SAVE_MESSAGE_UPDATE=true
DATABASE_SAVE_DATA_CONTACTS=true
DATABASE_SAVE_DATA_CHATS=true
DATABASE_SAVE_DATA_LABELS=true
DATABASE_SAVE_DATA_HISTORIC=true

# ── Cache (Redis do compose) ────────────────────────────────────────────────
CACHE_REDIS_ENABLED=true
CACHE_REDIS_URI=redis://redis:6379/6
CACHE_REDIS_PREFIX_KEY=evolution
CACHE_REDIS_TTL=604800
CACHE_LOCAL_ENABLED=false

# ── Sessão/QR Code (Baileys) ────────────────────────────────────────────────
CONFIG_SESSION_PHONE_CLIENT=VamoAgendar
CONFIG_SESSION_PHONE_NAME=Chrome
QRCODE_LIMIT=30

# ── Comportamento ───────────────────────────────────────────────────────────
# false = instância desconectada NÃO é apagada automaticamente
DEL_INSTANCE=false
WEBHOOK_GLOBAL_ENABLED=false
LOG_LEVEL=ERROR,WARN,INFO
LOG_COLOR=true
LOG_BAILEYS=error

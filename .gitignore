# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# supabase local
supabase/.temp/
supabase/.branches/

# obsidian — só o estado efêmero do editor (layout de painéis/abas e câmera do grafo);
# o resto de .obsidian/ (aparência, plugins, snippets) é config versionada
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/graph.json

# Sentry Config File
.env.sentry-build-plugin
